---
import Base from '../layouts/Base.astro';
import Feed from '../components/Feed';
import fs from 'node:fs';
import path from 'node:path';

const query = `query ($relativePath: String!) {
  page(relativePath: $relativePath) {
    title
    blocks {
      ... on PageBlocksVideo {
        __typename
        title
        embed
        description
        credits
        year
        showTitle
        fullscreen
        bgColor
        textColor
      }
      ... on PageBlocksDisco {
        __typename
        title
        artist
        year
        cover
        tracks { title file }
        description
        credits
        showTitle
        fullscreen
        bgColor
        textColor
      }
      ... on PageBlocksFoto {
        __typename
        title
        images
        credits
        showTitle
        fullscreen
        bgColor
        textColor
      }
      ... on PageBlocksTexto {
        __typename
        title
        content
        year
        credits
        images
        showTitle
        fullscreen
        bgColor
        textColor
      }
      ... on PageBlocksBio {
        __typename
        title
        content
        images
        credits
        bgColor
        textColor
      }
    }
  }
}`;

const variables = { relativePath: 'home.mdx' };

let data: any = {};

// Read MDX frontmatter directly — works in build and dev
try {
  const mdxPath = path.resolve('src/content/pages/home.mdx');
  const raw = fs.readFileSync(mdxPath, 'utf-8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---/);
  if (fmMatch) {
    const yaml = await import('js-yaml');
    // @ts-ignore
    const parsed = yaml.default ? yaml.default.load(fmMatch[1]) : yaml.load(fmMatch[1]);
    const blocks = (parsed.blocks || []).map((b: any) => {
      const templateMap: Record<string, string> = {
        video: 'PageBlocksVideo',
        disco: 'PageBlocksDisco',
        foto: 'PageBlocksFoto',
        texto: 'PageBlocksTexto',
        bio: 'PageBlocksBio',
      };
      return { ...b, __typename: templateMap[b._template] || b._template };
    });
    data = { page: { title: parsed.title, blocks } };
  }
} catch (e) {
  console.warn('Failed to read home.mdx:', e);
}
---
<Base>
  <nav class="nav nav--top">
    <button class="nav__filter active" data-filter="videos">Videos</button>
    <button class="nav__filter active" data-filter="musica">Discos</button>
    <button class="nav__filter active" data-filter="fotos">Fotos</button>
  </nav>
  <nav class="nav nav--bottom">
    <button class="nav__filter active" data-filter="textos">Textos</button>
    <button class="nav__filter active" data-filter="bio">Curry</button>
    <button class="nav__sound" id="sound-toggle" aria-label="Sonido"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M3 9v6h4l5 5V4L7 9H3z"/><path class="sound-waves" d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg></button>
    <a href="https://github.com/catuy/hectorbardanca.uy" class="nav__code" target="_blank" aria-label="Código fuente">&lt;/&gt;</a>
  </nav>
  <Feed client:load query={query} variables={variables} data={data} />
</Base>
