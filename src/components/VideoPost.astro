---
interface Props {
  title: string;
  embed: string;
  label?: string;
}
const { title, embed, label } = Astro.props;
---
<article class="post post-video" data-category="videos">
  <iframe class="post-video__embed" src={embed} allowfullscreen loading="lazy"></iframe>
  {label && <span class="post-video__label">{label}</span>}
</article>
